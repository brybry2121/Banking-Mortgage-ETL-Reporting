<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>dsMortgageOLAP</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>ee010fd5-be79-4192-9161-cbfa1fb71675</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Loan_To_Date_By_MaritalStatus">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>WITH 
Periods AS (
    SELECT 'YearToDate' AS Period, CAST('2022-01-01' AS DATE) AS DateStart, CAST('2022-12-31' AS DATE) AS DateEnd
    UNION ALL
    SELECT 'MonthToDate', CAST('2022-01-01' AS DATE), CAST('2022-01-31' AS DATE)
    UNION ALL
    SELECT 'WeekToDate', CAST('2022-01-01' AS DATE), CAST('2022-01-07' AS DATE)
),
MaritalStatusList AS (
    SELECT DISTINCT 
        CASE 
            WHEN Marital_Status IN ('Divorsed') THEN 'Divorced'
            WHEN Marital_Status IS NULL THEN 'Unknown'
            ELSE Marital_Status 
        END AS CleanStatus
    FROM Mortgage0.dbo.Master_Table_CombinedAll
)
SELECT 
    m.CleanStatus,
    p.Period,
    COUNT(t.Loan_ID) AS LoanCount
FROM 
    Periods p
CROSS JOIN 
    MaritalStatusList m
LEFT JOIN 
    Mortgage0.dbo.Master_Table_CombinedAll t
    ON 
        (CASE 
            WHEN t.Marital_Status IN ('Divorsed') THEN 'Divorced'
            WHEN t.Marital_Status IS NULL THEN 'Unknown'
            ELSE t.Marital_Status 
        END) = m.CleanStatus
        AND t.Loan_Date &gt;= p.DateStart
        AND t.Loan_Date &lt;= p.DateEnd
GROUP BY 
    m.CleanStatus, p.Period
ORDER BY 
    m.CleanStatus, 
    -- Forces: YearToDate, MonthToDate, WeekToDate order
    CASE 
        WHEN p.Period = 'YearToDate' THEN 1
        WHEN p.Period = 'MonthToDate' THEN 2
        WHEN p.Period = 'WeekToDate' THEN 3
        ELSE 4
    END</CommandText>
      </Query>
      <Fields>
        <Field Name="CleanStatus">
          <DataField>CleanStatus</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Period">
          <DataField>Period</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LoanCount">
          <DataField>LoanCount</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
