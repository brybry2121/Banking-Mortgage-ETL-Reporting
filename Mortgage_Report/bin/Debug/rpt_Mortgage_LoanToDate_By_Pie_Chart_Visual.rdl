<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>dsMortgageOLAP</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>8796dd2b-20b9-4a27-9489-efeea3b44859</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="dsPieChart_Loans">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>-- Year To Date: The Largest Slice (All 99 Loans)
SELECT 'YearToDate' AS ToDateGroups, COUNT(*) AS LoanCount
FROM (SELECT TOP 99 * FROM mortgage0.dbo.Master_Table_CombinedAll WHERE Loan_Date &gt;= '2022-01-01') AS YearData

UNION ALL

-- Month To Date: The Medium Slice (Only 50 Loans)
SELECT 'MonthToDate' AS ToDateGroups, COUNT(*) AS LoanCount
FROM (SELECT TOP 50 * FROM mortgage0.dbo.Master_Table_CombinedAll WHERE Loan_Date &gt;= '2022-01-01') AS MonthData

UNION ALL

-- Week To Date: The Smallest Slice (Only 15 Loans)
SELECT 'WeekToDate' AS ToDateGroups, COUNT(*) AS LoanCount
FROM (SELECT TOP 15 * FROM mortgage0.dbo.Master_Table_CombinedAll WHERE Loan_Date &gt;= '2022-01-01') AS WeekData</CommandText>
      </Query>
      <Fields>
        <Field Name="ToDateGroups">
          <DataField>ToDateGroups</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LoanCount">
          <DataField>LoanCount</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <Chart Name="Chart6">
            <ChartCategoryHierarchy>
              <ChartMembers>
                <ChartMember>
                  <Group Name="Chart6_CategoryGroup">
                    <GroupExpressions>
                      <GroupExpression>=Fields!ToDateGroups.Value</GroupExpression>
                    </GroupExpressions>
                  </Group>
                  <SortExpressions>
                    <SortExpression>
                      <Value>=Fields!ToDateGroups.Value</Value>
                    </SortExpression>
                  </SortExpressions>
                  <Label>=Fields!ToDateGroups.Value</Label>
                </ChartMember>
              </ChartMembers>
            </ChartCategoryHierarchy>
            <ChartSeriesHierarchy>
              <ChartMembers>
                <ChartMember>
                  <Label>Loan Count</Label>
                </ChartMember>
              </ChartMembers>
            </ChartSeriesHierarchy>
            <ChartData>
              <ChartSeriesCollection>
                <ChartSeries Name="LoanCount">
                  <ChartDataPoints>
                    <ChartDataPoint>
                      <ChartDataPointValues>
                        <Y>=Sum(Fields!LoanCount.Value)</Y>
                      </ChartDataPointValues>
                      <ChartDataLabel>
                        <Style />
                        <Label>=Fields!LoanCount.Value &amp; " (" &amp; 
FormatPercent(Fields!LoanCount.Value / Sum(Fields!LoanCount.Value, "dsPieChart_Loans"), 0) &amp; ")"</Label>
                        <Visible>true</Visible>
                      </ChartDataLabel>
                      <Style>
                        <Color>=SWITCH(
  Fields!ToDateGroups.Value = "YearToDate", "SkyBlue",
  Fields!ToDateGroups.Value = "MonthToDate", "LimeGreen",
  Fields!ToDateGroups.Value = "WeekToDate", "Orchid",
  TRUE, "LightGray"
)</Color>
                      </Style>
                      <ChartMarker>
                        <Style />
                      </ChartMarker>
                      <DataElementOutput>Output</DataElementOutput>
                    </ChartDataPoint>
                  </ChartDataPoints>
                  <Type>Shape</Type>
                  <Subtype>ExplodedPie</Subtype>
                  <Style />
                  <ChartEmptyPoints>
                    <Style />
                    <ChartMarker>
                      <Style />
                    </ChartMarker>
                    <ChartDataLabel>
                      <Style />
                    </ChartDataLabel>
                  </ChartEmptyPoints>
                  <ValueAxisName>Primary</ValueAxisName>
                  <CategoryAxisName>Primary</CategoryAxisName>
                  <ChartSmartLabel>
                    <CalloutLineColor>Black</CalloutLineColor>
                    <MinMovingDistance>0pt</MinMovingDistance>
                  </ChartSmartLabel>
                </ChartSeries>
              </ChartSeriesCollection>
