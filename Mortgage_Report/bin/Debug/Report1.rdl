                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=IIF(Fields!LoanAmount.Value = 0, 0, Fields!MonthlyIncome.Value / Fields!LoanAmount.Value)</Value>
                                  <Style>
                                    <FontFamily>Arial</FontFamily>
                                    <Format>0.00%</Format>
