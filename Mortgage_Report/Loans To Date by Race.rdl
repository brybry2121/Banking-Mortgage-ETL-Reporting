<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>dsMortgageOLAP</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>7fa2be2a-c7a1-475d-8986-baea48adf408</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>WITH 
Periods AS (
    SELECT 'YearToDate' AS Period, '2022-01-01' AS DateStart, '2022-12-31' AS DateEnd
    UNION ALL
    SELECT 'MonthToDate', '2022-01-01', '2022-01-31'
    UNION ALL
    SELECT 'WeekToDate', '2022-01-10', '2022-01-16'
),
RaceGroups AS (
    SELECT DISTINCT [Race]
    FROM Mortgage0.dbo.Master_Table_CombinedAll
),
LoanFacts AS (
    SELECT 
        Loan_ID, 
        Loan_Date,
        [Race]
    FROM Mortgage0.dbo.Master_Table_CombinedAll
    WHERE [Race] IS NOT NULL AND [Race] &lt;&gt; ''
)
SELECT 
    r.[Race],
    p.Period,
    COUNT(l.Loan_ID) AS LoanCount
FROM 
    Periods p
CROSS JOIN 
    RaceGroups r
LEFT JOIN 
    LoanFacts l
        ON l.[Race] = r.[Race]
        AND l.Loan_Date &gt;= p.DateStart
        AND l.Loan_Date &lt;= p.DateEnd
GROUP BY 
    r.[Race], p.Period
ORDER BY 
    r.[Race],
    CASE p.Period
        WHEN 'YearToDate' THEN 1
        WHEN 'MonthToDate' THEN 2
        WHEN 'WeekToDate' THEN 3
        ELSE 4
    END</CommandText>
      </Query>
      <Fields>
        <Field Name="Race">
          <DataField>Race</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Period">
          <DataField>Period</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LoanCount">
          <DataField>LoanCount</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
