<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>dsMortgageOLAP</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>cdff3cca-08d7-4478-b9d5-8151fa3cbaa1</rd:DataSourceID>
    </DataSource>
    <DataSource Name="DataSource2">
      <DataSourceReference>Mortgage0DataSource</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>1214525f-2944-4fbf-a606-bb4723bbb58c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource2</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Period">
            <Value>=Parameters!Period.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Sex">
            <Value>=Parameters!Sex.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Race">
            <Value>=Parameters!Race.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT 
                  Loan_ID, Borrower_FirstName + ' ' + Borrower_LastName AS BorrowerName, Loan_Date AS ReportMonth, MonthlyIncome, Bonuses, Commission, OtherIncome, Sex, Race, 
                  CASE WHEN MonthlyIncome * 1.0 / 100000 &gt; 0.10 THEN 'Green' WHEN MonthlyIncome * 1.0 / 100000 &gt;= 0.07 THEN 'Yellow' ELSE 'Red' END AS RiskArrow
FROM     Master_Table_CombinedAll
WHERE  (@Period = 'WeekToDate') AND (Loan_Date BETWEEN '2022-01-10' AND '2022-01-17') AND (Sex = @Sex OR
                  @Sex = 'All' OR
                  @Sex IS NULL) AND (Race = @Race OR
                  @Race = 'All' OR
                  @Race IS NULL) AND (Loan_ID IS NOT NULL) OR
                  (@Period = 'MonthToDate') AND (Loan_Date BETWEEN '2022-01-01' AND '2022-01-31') AND (Sex = @Sex OR
                  @Sex = 'All' OR
                  @Sex IS NULL) AND (Race = @Race OR
                  @Race = 'All' OR
                  @Race IS NULL) AND (Loan_ID IS NOT NULL) OR
                  (@Period = 'YearToDate') AND (Loan_Date BETWEEN '2022-01-01' AND '2022-12-31') AND (Sex = @Sex OR
                  @Sex = 'All' OR
                  @Sex IS NULL) AND (Race = @Race OR
                  @Race = 'All' OR
                  @Race IS NULL) AND (Loan_ID IS NOT NULL) OR
                  (@Period = 'All' OR
                  @Period IS NULL) AND (Sex = @Sex OR
                  @Sex = 'All' OR
                  @Sex IS NULL) AND (Race = @Race OR
                  @Race = 'All' OR
                  @Race IS NULL) AND (Loan_ID IS NOT NULL)
ORDER BY Loan_ID</CommandText>
      </Query>
      <Fields>
        <Field Name="Loan_ID">
          <DataField>Loan_ID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="BorrowerName">
          <DataField>BorrowerName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ReportMonth">
          <DataField>ReportMonth</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="MonthlyIncome">
          <DataField>MonthlyIncome</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="Bonuses">
          <DataField>Bonuses</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="Commission">
          <DataField>Commission</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="OtherIncome">
          <DataField>OtherIncome</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="Sex">
          <DataField>Sex</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Race">
          <DataField>Race</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="RiskArrow">
          <DataField>RiskArrow</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
