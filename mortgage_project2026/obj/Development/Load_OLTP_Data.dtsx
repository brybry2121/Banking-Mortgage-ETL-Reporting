          <ProjectItem
            Name="ScriptMain.cs"
            Encoding="UTF8"><![CDATA[using System;
using Microsoft.SqlServer.Dts.Runtime;

namespace ST_NewScriptTask
{
    [Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
    public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
    {
        public void Main()
        {
            try
            {
                // Get the file path
                string filePath = Dts.Variables["File_Name"].Value.ToString();

                // Check if file exists
                if (System.IO.File.Exists(filePath))
                {
                    Dts.Variables["ErrorsInSource"].Value = 0;
                    Dts.Variables["Body"].Value = "File validation successful.";
                    Dts.TaskResult = (int)ScriptResults.Success;
                }
                else
                {
                    Dts.Variables["ErrorsInSource"].Value = 1;
                    Dts.Variables["Body"].Value = $"Error: File not found at {filePath}";
                    Dts.TaskResult = (int)ScriptResults.Failure;
                }
            }
            catch (Exception ex)
            {
                Dts.Variables["ErrorsInSource"].Value = 1;
                Dts.Variables["Body"].Value = $"Script Error: {ex.Message}";
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        #region ScriptResults declaration
        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        };
        #endregion
    }
}]]></ProjectItem>
