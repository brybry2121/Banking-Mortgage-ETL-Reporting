          <ProjectItem
            Name="ScriptMain.cs"
            Encoding="UTF8"><![CDATA[#region Namespaces
using System;
using System.Data;
using Microsoft.SqlServer.Dts.Runtime;
using System.Windows.Forms;
using System.Net;
using System.Net.Mail;
using System.IO;
#endregion

namespace ST_SendEmail
{
    [Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
    public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
    {
        public void Main()
        {
            try
            {
                // ===== EMAIL CONFIGURATION =====
                string fromEmail = "biretes@gmail.com";
                string appPassword = "tprwyprdffmqdfox";
                string smtpServer = "smtp.gmail.com";
                int smtpPort = 587;

                // Get recipient from SSIS variable
                string toEmail = Dts.Variables["Email_Recipients"].Value.ToString();

                // Corrected File Path (Single OneDrive/Documents folder)
                string attachmentPath = @"C:\Users\biret\OneDrive\Documents\Bad_data\Bad_data.txt";

                // Email content
                string subject = "Mortgage Data Quality Issues - Action Required";
                string body = $@"Dear Mortgage Officer,

We found data quality issues during the staging process.

ISSUE SUMMARY:
- Bad data rows found and exported to attached file
- File: Bad_data.txt

ACTION REQUIRED:
1. Review the attached Bad_data.txt file
2. Correct all data quality issues
3. Send the corrected data back in XML format

FILE LOCATION:
{attachmentPath}

Once you send the corrected XML file, we will process it and complete the data load.

Thank you for your prompt attention to this matter.

Best regards,
Mortgage Data Quality Team";

                // Create mail message
                MailMessage mail = new MailMessage();
                mail.From = new MailAddress(fromEmail);
                mail.To.Add(toEmail);
                mail.Subject = subject;
                mail.Body = body;
                mail.IsBodyHtml = false;
                mail.Priority = MailPriority.High;

                // Add attachment if file exists
                if (File.Exists(attachmentPath))
                {
                    Attachment attachment = new Attachment(attachmentPath);
                    mail.Attachments.Add(attachment);

                    bool fireAgain = false;
                    Dts.Events.FireInformation(0, "Send Email",
                        $"Attachment added: {attachmentPath}", "", 0, ref fireAgain);
                }
                else
                {
                    Dts.Events.FireWarning(0, "Send Email",
                        $"Attachment file not found: {attachmentPath}. Email sent without attachment.", "", 0);
                }

                // Configure SMTP client
                SmtpClient smtpClient = new SmtpClient(smtpServer, smtpPort);
                smtpClient.Credentials = new NetworkCredential(fromEmail, appPassword);
                smtpClient.EnableSsl = true;
                smtpClient.Timeout = 30000;

                // Send email
                smtpClient.Send(mail);

                bool fireAgain2 = false;
                Dts.Events.FireInformation(0, "Send Email",
                    $"Email sent successfully to: {toEmail}", "", 0, ref fireAgain2);

                Dts.TaskResult = (int)ScriptResults.Success;
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Send Email Script",
                    $"Error sending email: {ex.Message}", "", 0);

                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        #region ScriptResults declaration
        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
